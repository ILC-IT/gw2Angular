# ================================================================================================
# Dockerfile para produccion
# Clona codigo desde GitHub
# Version 2: Clonando codigo desde GitHub
# Se asume que quieres dar solo el Dockerfile y que el contenedor descargue el codigo desde GitHub
# Uso:
# docker build -f Dockerfile-github -t gw2Angular-github .
# docker run -d -p 4202:80 --name gw2Angular-github --restart unless-stopped gw2Angular-github
# Abrir la app en http://localhost:4202
# ================================================================================================

# 1 Build de Angular
FROM node:16.20.2 AS build

WORKDIR /app

# Instalar git para clonar el repositorio
RUN apt-get update && apt-get install -y git && rm -rf /var/lib/apt/lists/*

# Clonar tu repositorio (reemplaza URL y rama)
RUN git clone --branch main --depth 1 https://github.com/ILC-IT/gw2Angular /app

# Instalar dependencias
RUN npm ci

# Compilar la app Angular en modo produccion
RUN npx ng build --configuration production

# 2 Servir con Nginx
FROM nginx:stable-alpine

# Copiar archivos compilados a Nginx
COPY --from=build /app/dist/gw2Angular /usr/share/nginx/html

# Copiar configuracion personalizada de Nginx
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
